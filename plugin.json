{
  "spec": "soksak-spec-plugin@0.0.1",
  "id": "soksak-plugin-mascot",
  "name": {
    "en": "Mascot",
    "ko": "\ub9c8\uc2a4\ucf54\ud2b8"
  },
  "version": "0.0.1",
  "description": {
    "en": "Character presentation engine \u2014 a Live2D mascot overlay with local neural TTS, measured lip-sync, expressions and motions. No views of its own: other plugins (activity log, chat UIs) drive it through commands (say/expression/motion/mascot).",
    "ko": "\uce90\ub9ad\ud130 \ud45c\ud604 \uc5d4\uc9c4 \u2014 Live2D \ub9c8\uc2a4\ucf54\ud2b8 \uc624\ubc84\ub808\uc774 + \ub85c\uceec \uc2e0\uacbd TTS, \uc2e4\uce21 \ub9bd\uc2f1\ud06c, \ud45c\uc815\u00b7\ubaa8\uc158. \uc790\uccb4 \ubdf0 \uc5c6\uc74c: \ub2e4\ub978 \ud50c\ub7ec\uadf8\uc778(\ud65c\ub3d9\ub85c\uadf8\u00b7\ub300\ud654 UI)\uc774 \ucee4\ub9e8\ub4dc(say/expression/motion/mascot)\ub85c \uad6c\ub3d9\ud55c\ub2e4."
  },
  "entry": "main.js",
  "permissions": [
    "ui",
    "ui:overlay:screen",
    "commands",
    "process",
    "network",
    "data",
    "notify",
    "fs:read"
  ],
  "configuration": [
    {
      "key": "modelPath",
      "type": "string",
      "default": "",
      "title": {
        "en": "Live2D model (.model3.json)",
        "ko": "Live2D \ubaa8\ub378 (.model3.json)"
      },
      "description": {
        "en": "Absolute path to the character's .model3.json. Changing it switches the character live.",
        "ko": "\uce90\ub9ad\ud130 .model3.json \uc808\ub300 \uacbd\ub85c. \ubc14\uafb8\uba74 \uce90\ub9ad\ud130\uac00 \uc989\uc2dc \uad50\uccb4\ub41c\ub2e4."
      }
    },
    {
      "key": "modelsDir",
      "type": "string",
      "default": "",
      "title": {
        "en": "Characters folder",
        "ko": "\uce90\ub9ad\ud130 \ud3f4\ub354"
      },
      "description": {
        "en": "Directory scanned for Live2D characters (recursively finds *.model3.json). Empty = the plugin's models/ folder. Pick a character with the model.load command.",
        "ko": "Live2D \uce90\ub9ad\ud130 \uc2a4\uce94 \ub514\ub809\ud1a0\ub9ac(*.model3.json \uc7ac\uadc0 \ud0d0\uc0c9). \ube44\uc6b0\uba74 \ud50c\ub7ec\uadf8\uc778\uc758 models/ \ud3f4\ub354. \uc120\ud0dd\uc740 \ube0c\uc774\ud29c\ubc84 \ud328\ub110 \ud234\ubc14\uc5d0\uc11c."
      }
    },
    {
      "key": "voiceName",
      "type": "string",
      "default": "",
      "title": {
        "en": "Voice",
        "ko": "\ubaa9\uc18c\ub9ac"
      },
      "description": {
        "en": "OS voice name (partial match, e.g. \"Yuna\"). Empty = locale-preferred voice. List candidates with the state command ({\"voices\":true}).",
        "ko": "OS \ubcf4\uc774\uc2a4 \uc774\ub984(\ubd80\ubd84\uc77c\uce58, \uc608: \"Yuna\"). \ube44\uc6b0\uba74 \ub85c\ucf00\uc77c \uc120\ud638 \ubcf4\uc774\uc2a4. \ud6c4\ubcf4 \ubaa9\ub85d\uc740 state \ucee4\ub9e8\ub4dc({\"voices\":true})."
      }
    },
    {
      "key": "speechSidecarBin",
      "type": "string",
      "default": "",
      "title": {
        "en": "Speech sidecar binary",
        "ko": "\uc74c\uc131 \uc0ac\uc774\ub4dc\uce74 \ubc14\uc774\ub108\ub9ac"
      },
      "description": {
        "en": "Path to soksak-sidecar-speech-sherpa. When set together with the model dir, local neural TTS replaces the OS voice (real lip-sync).",
        "ko": "soksak-sidecar-speech-sherpa \ubc14\uc774\ub108\ub9ac \uacbd\ub85c. \ubaa8\ub378 \ub514\ub809\ud1a0\ub9ac\uc640 \ud568\uaed8 \uc9c0\uc815\ud558\uba74 \ub85c\uceec \uc2e0\uacbd TTS \uac00 OS \uc74c\uc131\uc744 \ub300\uccb4\ud55c\ub2e4(\uc2e4\uce21 \ub9bd\uc2f1\ud06c)."
      }
    },
    {
      "key": "speechModelDir",
      "type": "string",
      "default": "",
      "title": {
        "en": "Speech model dir",
        "ko": "\uc74c\uc131 \ubaa8\ub378 \ub514\ub809\ud1a0\ub9ac"
      },
      "description": {
        "en": "sherpa-onnx TTS model directory (*.onnx, tokens.txt, \u2026). Check the model's own license before use.",
        "ko": "sherpa-onnx TTS \ubaa8\ub378 \ub514\ub809\ud1a0\ub9ac(*.onnx, tokens.txt, \u2026). \ubaa8\ub378 \uc790\uccb4 \ub77c\uc774\uc120\uc2a4\ub97c \ud655\uc778\ud558\uace0 \uc0ac\uc6a9."
      }
    },
    {
      "key": "speechEngine",
      "type": "enum",
      "default": "supertonic",
      "enum": [
        "vits",
        "kokoro",
        "supertonic"
      ],
      "enumLabels": [
        {
          "en": "VITS (sherpa)",
          "ko": "VITS (sherpa)"
        },
        {
          "en": "Kokoro (sherpa)",
          "ko": "Kokoro (sherpa)"
        },
        {
          "en": "Supertonic",
          "ko": "Supertonic"
        }
      ],
      "title": {
        "en": "Speech engine",
        "ko": "\uc74c\uc131 \uc5d4\uc9c4"
      },
      "description": {
        "en": "Model family of the speech model dir. supertonic expects onnx/ + voice_styles/ (speaker id picks a style).",
        "ko": "\uc74c\uc131 \ubaa8\ub378 \ub514\ub809\ud1a0\ub9ac\uc758 \ubaa8\ub378 \uacc4\uc5f4. supertonic \uc740 onnx/ + voice_styles/ \uad6c\uc870(\ud654\uc790 \ubc88\ud638=\uc2a4\ud0c0\uc77c \uc120\ud0dd)."
      }
    },
    {
      "key": "speechSpeakerId",
      "type": "number",
      "default": 0,
      "min": 0,
      "title": {
        "en": "Speaker id",
        "ko": "\ud654\uc790 \ubc88\ud638"
      },
      "description": {
        "en": "Voice within a multi-speaker model (0-based). Valid range shows as sidecarInfo.numSpeakers in the state command. Single-speaker models ignore this.",
        "ko": "\uba40\ud2f0\uc2a4\ud53c\ucee4 \ubaa8\ub378 \uc548\uc758 \uc74c\uc131 \uc120\ud0dd(0\ubd80\ud130). \uc720\ud6a8 \ubc94\uc704\ub294 state \ucee4\ub9e8\ub4dc\uc758 sidecarInfo.numSpeakers. \ub2e8\uc77c \ud654\uc790 \ubaa8\ub378\uc740 \ubb34\uc2dc."
      }
    },
    {
      "key": "speechSpeed",
      "type": "number",
      "default": 1,
      "min": 0.5,
      "max": 3,
      "title": {
        "en": "Speech speed",
        "ko": "\ubc1c\ud654 \uc18d\ub3c4"
      },
      "description": {
        "en": "1 = model default.",
        "ko": "1 = \ubaa8\ub378 \uae30\ubcf8 \uc18d\ub3c4."
      }
    }
  ],
  "implements": [
    {
      "id": "soksak-spec-plugin-narration",
      "version": "0.0.1"
    }
  ],
  "contributes": {
    "commands": [
      {
        "name": "ping",
        "title": {
          "en": "Pings the plugin",
          "ko": "\ud50c\ub7ec\uadf8\uc778 \uc0c1\ud0dc\ub97c \uc810\uac80\ud569\ub2c8\ub2e4"
        }
      },
      {
        "name": "say",
        "title": {
          "en": "Speaks text with expressions (no LLM)",
          "ko": "\ud14d\uc2a4\ud2b8\ub97c \ud45c\uc815\uacfc \ud568\uaed8 \ubc1c\ud654\ud569\ub2c8\ub2e4"
        }
      },
      {
        "name": "release",
        "title": {
          "en": "Releases engine resources",
          "ko": "\uc5d4\uc9c4 \uc790\uc6d0\uc744 \ubc18\ub0a9\ud569\ub2c8\ub2e4"
        }
      },
      {
        "name": "stop",
        "title": {
          "en": "Stops speech and the current turn",
          "ko": "\ubc1c\ud654\uc640 \uc9c4\ud589 \uc911 \ud134\uc744 \uc911\ub2e8\ud569\ub2c8\ub2e4"
        }
      },
      {
        "name": "state",
        "title": {
          "en": "Reads plugin state",
          "ko": "\ud50c\ub7ec\uadf8\uc778 \uc0c1\ud0dc\ub97c \uc870\ud68c\ud569\ub2c8\ub2e4"
        }
      },
      {
        "name": "model.list",
        "title": {
          "en": "Lists characters in the models folder",
          "ko": "\uce90\ub9ad\ud130 \ud3f4\ub354\uc758 \ubaa8\ub378\uc744 \ub098\uc5f4\ud569\ub2c8\ub2e4"
        }
      },
      {
        "name": "model.load",
        "title": {
          "en": "Loads a Live2D model",
          "ko": "Live2D \ubaa8\ub378\uc744 \ub85c\ub4dc\ud569\ub2c8\ub2e4"
        }
      },
      {
        "name": "expression.list",
        "title": {
          "en": "Lists model expressions",
          "ko": "\ubaa8\ub378 \ud45c\uc815 \ubaa9\ub85d\uc744 \uc870\ud68c\ud569\ub2c8\ub2e4"
        }
      },
      {
        "name": "expression.set",
        "title": {
          "en": "Applies a model expression",
          "ko": "\ubaa8\ub378 \ud45c\uc815\uc744 \uc801\uc6a9\ud569\ub2c8\ub2e4"
        }
      },
      {
        "name": "emotion.map",
        "title": {
          "en": "Sets emotion\u2192expression mapping",
          "ko": "\uac10\uc815-\ud45c\uc815 \ub9e4\ud551\uc744 \uc124\uc815\ud569\ub2c8\ub2e4"
        }
      },
      {
        "name": "motion.play",
        "title": {
          "en": "Plays a model motion",
          "ko": "\ubaa8\ub378 \ubaa8\uc158\uc744 \uc7ac\uc0dd\ud569\ub2c8\ub2e4"
        }
      },
      {
        "name": "cubism.install",
        "title": {
          "en": "Downloads Cubism Core after license consent",
          "ko": "\ub77c\uc774\uc120\uc2a4 \ub3d9\uc758 \ud6c4 Cubism Core\ub97c \ub0b4\ub824\ubc1b\uc2b5\ub2c8\ub2e4"
        }
      },
      {
        "name": "toggle",
        "title": {
          "en": "Toggles the screen mascot overlay",
          "ko": "\ud654\uba74 \ub9c8\uc2a4\ucf54\ud2b8 \uc624\ubc84\ub808\uc774\ub97c \ucf1c\uace0 \ub055\ub2c8\ub2e4"
        }
      },
      {
        "name": "tts.toggle",
        "title": {
          "en": "Toggles speech output",
          "ko": "\uc74c\uc131 \ucd9c\ub825\uc744 \ucf1c\uace0 \ub055\ub2c8\ub2e4"
        }
      }
    ]
  }
}
