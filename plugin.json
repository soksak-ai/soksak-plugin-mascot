{
  "spec": "soksak-spec-plugin@0.0.1",
  "id": "soksak-plugin-vtuber",
  "name": {
    "en": "VTuber",
    "ko": "브이튜버"
  },
  "version": "0.0.1",
  "repo": "https://github.com/soksak-ai/soksak-plugin-vtuber.git",
  "description": {
    "en": "Live2D avatar companion — chat with a local AI agent; the avatar reacts with expressions, subtitles, and speech. Panel view and screen mascot overlay. Bring your own Live2D model (.model3.json).",
    "ko": "Live2D 아바타 컴패니언 — 로컬 AI 에이전트와 대화하면 아바타가 표정·자막·음성으로 반응한다. 패널 뷰와 화면 마스코트 오버레이. Live2D 모델(.model3.json)은 사용자가 지정."
  },
  "entry": "main.js",
  "permissions": [
    "ui",
    "ui:overlay:screen",
    "commands",
    "programs",
    "network",
    "data",
    "notify",
    "fs:read"
  ],
  "dependencies": {
    "soksak-plugin-agents-acp": "^0.1.0"
  },
  "configuration": [
    {
      "key": "modelPath",
      "type": "string",
      "default": "",
      "title": {
        "en": "Live2D model (.model3.json)",
        "ko": "Live2D 모델 (.model3.json)"
      },
      "description": {
        "en": "Absolute path to the character's .model3.json. Changing it switches the character live.",
        "ko": "캐릭터 .model3.json 절대 경로. 바꾸면 캐릭터가 즉시 교체된다."
      }
    },
    {
      "key": "agent",
      "type": "enum",
      "default": "claude",
      "enum": [
        "claude",
        "codex",
        "gemini"
      ],
      "enumLabels": [
        {
          "en": "Claude",
          "ko": "Claude"
        },
        {
          "en": "Codex (ChatGPT)",
          "ko": "Codex (ChatGPT)"
        },
        {
          "en": "Gemini",
          "ko": "Gemini"
        }
      ],
      "title": {
        "en": "Chat agent",
        "ko": "대화 에이전트"
      },
      "description": {
        "en": "Which local agent (via agents-acp) answers the chat. Switching reconnects on the next turn.",
        "ko": "대화에 답할 로컬 에이전트(agents-acp 경유). 바꾸면 다음 턴에 재연결된다."
      }
    },
    {
      "key": "agentModel",
      "type": "string",
      "default": "",
      "title": {
        "en": "Agent model",
        "ko": "에이전트 모델"
      },
      "description": {
        "en": "Model id for the agent session (e.g. gpt-5.4-mini[low] for codex). Empty = agent default. Available ids are printed by the agent's session.",
        "ko": "에이전트 세션 모델 id (예: codex 는 gpt-5.4-mini[low]). 비우면 에이전트 기본값."
      }
    },
    {
      "key": "voiceName",
      "type": "string",
      "default": "",
      "title": {
        "en": "Voice",
        "ko": "목소리"
      },
      "description": {
        "en": "OS voice name (partial match, e.g. \"Yuna\"). Empty = locale-preferred voice. List candidates with vtuber.state {\"voices\":true}.",
        "ko": "OS 보이스 이름(부분일치, 예: \"Yuna\"). 비우면 로케일 선호 보이스. 후보 목록은 vtuber.state {\"voices\":true}."
      }
    }
  ],
  "contributes": {
    "views": [
      {
        "id": "vtuber",
        "title": {
          "en": "VTuber",
          "ko": "브이튜버"
        },
        "icon": "🎭",
        "placements": [
          "content"
        ],
        "defaultPlacement": "content"
      }
    ],
    "programs": [
      {
        "id": "vtuber",
        "title": {
          "en": "VTuber",
          "ko": "브이튜버"
        },
        "path": {
          "en": "Utility",
          "ko": "유틸리티"
        },
        "kind": "view",
        "view": "vtuber"
      }
    ],
    "commands": [
      {
        "name": "ping",
        "title": {
          "en": "Pings the plugin",
          "ko": "플러그인 상태를 점검합니다"
        }
      },
      {
        "name": "chat",
        "title": {
          "en": "Sends a chat turn to the agent",
          "ko": "에이전트와 대화합니다"
        }
      },
      {
        "name": "say",
        "title": {
          "en": "Speaks text with expressions (no LLM)",
          "ko": "텍스트를 표정과 함께 발화합니다"
        }
      },
      {
        "name": "stop",
        "title": {
          "en": "Stops speech and the current turn",
          "ko": "발화와 진행 중 턴을 중단합니다"
        }
      },
      {
        "name": "state",
        "title": {
          "en": "Reads plugin state",
          "ko": "플러그인 상태를 조회합니다"
        }
      },
      {
        "name": "model.load",
        "title": {
          "en": "Loads a Live2D model",
          "ko": "Live2D 모델을 로드합니다"
        }
      },
      {
        "name": "expression.list",
        "title": {
          "en": "Lists model expressions",
          "ko": "모델 표정 목록을 조회합니다"
        }
      },
      {
        "name": "expression.set",
        "title": {
          "en": "Applies a model expression",
          "ko": "모델 표정을 적용합니다"
        }
      },
      {
        "name": "emotion.map",
        "title": {
          "en": "Sets emotion→expression mapping",
          "ko": "감정-표정 매핑을 설정합니다"
        }
      },
      {
        "name": "cubism.install",
        "title": {
          "en": "Downloads Cubism Core after license consent",
          "ko": "라이선스 동의 후 Cubism Core를 내려받습니다"
        }
      },
      {
        "name": "mascot.toggle",
        "title": {
          "en": "Toggles the screen mascot overlay",
          "ko": "화면 마스코트 오버레이를 켜고 끕니다"
        }
      },
      {
        "name": "tts.toggle",
        "title": {
          "en": "Toggles speech output",
          "ko": "음성 출력을 켜고 끕니다"
        }
      }
    ]
  }
}
